<Window x:Class="TournamentTable.TournamentWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Турнирная таблица" Height="750" Width="850"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="220"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtTournamentTitle" Text="Загрузка турнира..." 
                       FontSize="20" FontWeight="Bold" Margin="0,0,0,15" Foreground="#1F2937"/>

            <DataGrid x:Name="dgTeams" Grid.Row="1" AutoGenerateColumns="False" 
                      IsReadOnly="True" GridLinesVisibility="Horizontal" 
                      Background="White" RowHeight="35" FontSize="13" AlternatingRowBackground="#F3F4F6">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="№" Binding="{Binding Position}" Width="50"/>
                    <DataGridTextColumn Header="Команда" Binding="{Binding Name}" Width="2*"/>
                    <DataGridTextColumn Header="Матчи" Binding="{Binding MatchesPlayed}" Width="*"/>
                    <DataGridTextColumn Header="Победы" Binding="{Binding Wins}" Width="*"/>
                    <DataGridTextColumn Header="Ничьи" Binding="{Binding Draws}" Width="*"/>
                    <DataGridTextColumn Header="Поражения" Binding="{Binding Losses}" Width="*"/>
                    <DataGridTextColumn Header="Очки" Binding="{Binding Points}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <TextBlock Grid.Row="2" Text="Дисквалифицированные команды:" FontWeight="Bold" Margin="0,15,0,5" Foreground="#6B7280"/>
            <DataGrid x:Name="dgDisqualified" Grid.Row="3" Height="120" AutoGenerateColumns="False" 
                      IsReadOnly="True" Background="#F3F4F6" GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Имя команды" Binding="{Binding Name}" Width="*"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Row="4" Background="#FFFFFF" BorderBrush="#E5E7EB" BorderThickness="1" 
                    CornerRadius="6" Padding="10" Margin="0,15,0,0">
                <StackPanel>
                    <TextBlock Text="Запись результата матча:" FontWeight="Bold" Margin="0,0,0,8" Foreground="#374151"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <ComboBox x:Name="cbTeam1" DisplayMemberPath="Name" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="vs" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <ComboBox x:Name="cbTeam2" Grid.Column="2" DisplayMemberPath="Name" Margin="0,0,5,0" VerticalAlignment="Center"/>

                        <StackPanel Grid.Column="3" Orientation="Horizontal" Margin="0,0,10,0" VerticalAlignment="Center">
                            <TextBox x:Name="txtScore1" Width="30" Text="0" TextAlignment="Center"/>
                            <TextBlock Text=":" Margin="4,0"/>
                            <TextBox x:Name="txtScore2" Width="30" Text="0" TextAlignment="Center"/>
                        </StackPanel>

                        <Button Grid.Column="4" Content="Записать" Click="BtnSaveMatch_Click" 
                                Background="#10B981" Foreground="White" Padding="8,5"/>
                    </Grid>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="15" 
                BorderBrush="#E5E7EB" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Управление" FontSize="16" FontWeight="Bold" 
                           Margin="0,0,0,20" Foreground="#374151" HorizontalAlignment="Center"/>

                <TextBlock Text="Сортировка:" FontSize="13" FontWeight="SemiBold" 
                           Foreground="#6B7280" Margin="0,0,0,8"/>

                <Button x:Name="btnSortByName" Content="По имени" Height="40" Margin="0,0,0,12"
                        Background="#4B5563" Foreground="White" Click="BtnSortByName_Click"/>

                <Button x:Name="btnSortByScore" Content="По очкам" Height="40" Margin="0,0,0,25"
                        Background="#3B82F6" Foreground="White" FontWeight="Bold" Click="BtnSortByScore_Click"/>

                <Separator Margin="0,0,0,20" Background="#E5E7EB"/>

                <Button x:Name="btnDisqualify" Content="Дисквалификация" Height="40" Margin="0,0,0,12"
                        Background="#EF4444" Foreground="White" FontWeight="Bold" Click="BtnDisqualify_Click"/>

                <Button x:Name="btnRestore" Content="Восстановить" Height="40" Margin="0,12,0,0"
                        Background="#10B981" Foreground="White" FontWeight="Bold" Click="BtnRestore_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>