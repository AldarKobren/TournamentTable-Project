<Window x:Class="TournamentTable.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор сезона" Height="400" Width="380"
        WindowStartupLocation="CenterScreen"
        Background="#F9FAFB">
    <Grid>
        <StackPanel Margin="30" VerticalAlignment="Center">

            <TextBlock Text="🏆 Турниры" FontSize="26" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,25" 
                       Foreground="#111827"/>
            <TextBlock Text="Выберите вид спорта:" Margin="0,0,0,8" 
                       FontWeight="SemiBold" Foreground="#374151"/>

            <ComboBox x:Name="cbSportType" Margin="0,0,0,15" Height="35" 
                      VerticalContentAlignment="Center" Foreground="#111827"
                      SelectionChanged="Cb_SelectionChanged">
                <ComboBoxItem Content="Футбол" Foreground="#111827"/>
                <ComboBoxItem Content="Баскетбол" Foreground="#111827"/>
                <ComboBoxItem Content="Волейбол" Foreground="#111827"/>
            </ComboBox>

            <TextBlock Text="Выберите номер сезона:" Margin="0,0,0,8" 
                       FontWeight="SemiBold" Foreground="#374151"/>

            <ComboBox x:Name="cbSeasonYear" Margin="0,0,0,30" Height="35" 
                      VerticalContentAlignment="Center" Foreground="#111827"
                      SelectionChanged="Cb_SelectionChanged">
                <ComboBoxItem Content="2024" Foreground="#111827"/>
                <ComboBoxItem Content="2025" Foreground="#111827"/>
                <ComboBoxItem Content="2026" Foreground="#111827"/>
            </ComboBox>

            <Button x:Name="btnShowTable" Content="Показать таблицу" Height="45" 
                    FontSize="15" FontWeight="Bold" 
                    IsEnabled="False" Click="BtnShowTable_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Background" Value="#2563EB"/>
                        <Style.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#E5E7EB"/>
                                <Setter Property="Foreground" Value="#9CA3AF"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Grid>
</Window>